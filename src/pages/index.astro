---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'cc-deck - Your Claude Code command center',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->

  <Hero
    tagline="Terminal-native &middot; Container-ready &middot; Multi-platform"
    actions={[
      {
        variant: 'primary',
        text: 'Get Started',
        href: '#get-started',
        icon: 'tabler:rocket',
      },
      {
        text: 'View on GitHub',
        href: 'https://github.com/cc-deck/cc-deck',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  >
    <Fragment slot="title">
      cc-deck<br /><span class="text-accent">Your Claude Code command center.</span>
    </Fragment>

    <Fragment slot="subtitle">
      The TweetDeck for Claude Code. Keep track of all your AI coding sessions from a single sidebar. See which session needs attention, switch instantly, and never lose context again.
    </Fragment>

    <Fragment slot="image">
      <div class="relative m-auto max-w-4xl">
        <div class="rounded-lg bg-slate-900 border border-slate-700 p-4 sm:p-6 shadow-2xl font-mono text-xs sm:text-sm text-slate-300 overflow-x-auto">
          <div class="flex items-center gap-2 mb-3 text-slate-500">
            <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
            <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
            <span class="ml-2 text-xs">terminal</span>
          </div>
          <pre class="whitespace-pre-wrap" set:html={`<span class="text-slate-500"># Start a ready-to-use Claude Code environment</span>
<span class="text-accent">$</span> <span class="text-amber-400">podman</span> run -d --name mydev \\
  -e ANTHROPIC_API_KEY=sk-ant-... \\
  <span class="text-emerald-400">quay.io/cc-deck/cc-deck-demo:latest</span>

<span class="text-accent">$</span> <span class="text-amber-400">podman</span> exec -it mydev \\
  <span class="text-emerald-400">cc-deck start</span>

<span class="text-slate-500"># A sidebar tracks all your Claude Code sessions.</span>
<span class="text-slate-500"># Smart attend switches to the one that needs you.</span>
<span class="text-slate-500"># Keyboard-driven. Works locally or on Kubernetes.</span>`} /></pre>
        </div>
      </div>
    </Fragment>
  </Hero>

  <!-- Core Value Proposition -->

  <Features
    id="pillars"
    tagline="Why cc-deck"
    title="Your sessions, under control"
    columns={2}
    items={[
      {
        title: 'Session Dashboard',
        description:
          'A real-time sidebar showing all your Claude Code sessions at a glance. See which sessions are working, which need permission, and which just finished. Think TweetDeck columns, but for AI coding sessions.',
        icon: 'tabler:layout-sidebar-right',
      },
      {
        title: 'Personal Dev Sandboxes',
        description:
          'Turn your local desktop environment into a portable container image. An LLM analyzes your repositories, discovers tool dependencies, resolves version conflicts, and generates an optimized sandbox with your exact toolchain. Rebuild anytime as your projects evolve.',
        icon: 'tabler:package',
      },
      {
        title: 'Multi-Platform',
        description:
          'Run locally in your terminal, in containers with mounted source code, or deploy on Kubernetes and OpenShift. Same experience everywhere. Persistent sessions across reconnects.',
        icon: 'tabler:device-desktop',
      },
      {
        title: 'Smart Attention Management',
        description:
          'Stop checking each session manually. Smart attend automatically cycles through sessions that need you, prioritizing permission requests over completed tasks. One keypress takes you where you are needed.',
        icon: 'tabler:bell-ringing',
      },
    ]}
  />

  <!-- Feature Details -->

  <Features
    id="features"
    tagline="Features"
    title="Everything you need for multi-session Claude Code"
    columns={3}
    items={[
      {
        title: 'Keyboard-First',
        description:
          'Navigate sessions with j/k, switch with Enter, go back with Esc. Search with /, pause with p, rename with r. Every action has a shortcut. Your hands never leave the keyboard.',
        icon: 'tabler:keyboard',
      },
      {
        title: 'Session Snapshots',
        description:
          'Save and restore session state across restarts. Auto-save on hooks. Name your snapshots. Resume exactly where you left off, even after a container restart.',
        icon: 'tabler:camera',
      },
      {
        title: 'AI-Driven Image Builder',
        description:
          'Point the LLM at your projects and it figures out what tools you need. It resolves conflicts in the discovered tooling, picks compatible versions, and generates a Containerfile that actually builds. When something breaks, it fixes and retries.',
        icon: 'tabler:hammer',
      },
      {
        title: 'Container-Ready',
        description:
          'Mount your source code as volumes. Pass API keys or Vertex AI credentials. Persistent containers you can connect to and disconnect from. Your environment, portable.',
        icon: 'tabler:container',
      },
      {
        title: 'Kubernetes Native',
        description:
          'Deploy your personal sandbox as a StatefulSet with persistent storage. Work from any machine, reconnect anytime. Same environment whether you are on your laptop or a remote cluster.',
        icon: 'tabler:cloud',
      },
      {
        title: 'Pause & Focus',
        description:
          'Pause sessions you are not actively working on. Paused sessions are excluded from smart attend rotation, letting you focus on what matters right now.',
        icon: 'tabler:player-pause',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features>

  <!-- Quickstart Steps -->

  <Steps
    id="get-started"
    tagline="Get Started"
    title="Running in two minutes"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Start the environment</span>',
        description:
          'Pull the demo image and start a persistent container with your API key: <code class="bg-slate-800 text-accent px-2 py-0.5 rounded text-sm">podman run -d --name mydev -e ANTHROPIC_API_KEY=sk-ant-... quay.io/cc-deck/cc-deck-demo:latest</code>',
        icon: 'tabler:container',
      },
      {
        title: 'Step 2: <span class="font-medium">Launch cc-deck</span>',
        description:
          'Connect and start the session dashboard: <code class="bg-slate-800 text-accent px-2 py-0.5 rounded text-sm">podman exec -it mydev cc-deck start</code>',
        icon: 'tabler:rocket',
      },
      {
        title: 'Step 3: <span class="font-medium">Start coding with Claude</span>',
        description:
          'Open new tabs and start Claude Code sessions. The sidebar tracks them all. Press Alt+n for smart attend, Alt+s to navigate between sessions.',
        icon: 'tabler:code',
      },
      {
        title: 'Step 4: <span class="font-medium">Build your personal sandbox</span>',
        description:
          'Create a container image from your local dev environment: <code class="bg-slate-800 text-accent px-2 py-0.5 rounded text-sm">cc-deck image init my-sandbox</code>. The LLM analyzes your repos, extracts tools, resolves conflicts, and builds your portable developer sandbox.',
        icon: 'tabler:hammer',
      },
    ]}
  />

  <!-- Call to Action -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Read the Docs',
        href: '/docs/',
        icon: 'tabler:book',
      },
      {
        text: 'View on GitHub',
        href: 'https://github.com/cc-deck/cc-deck',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  >
    <Fragment slot="title">
      Ready to take control of your Claude Code sessions?
    </Fragment>

    <Fragment slot="subtitle">
      Open source. Works locally, in containers, or on Kubernetes.
    </Fragment>
  </CallToAction>
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'cc-deck - Your Claude Code command center',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <section class="flex items-center justify-center min-h-[80vh] px-4">
    <div class="text-center max-w-3xl mx-auto">
      <div class="mb-6">
        <span
          class="inline-block bg-accent/10 text-accent text-sm font-semibold px-4 py-1.5 rounded-full border border-accent/20"
        >
          Coming Soon
        </span>
      </div>

      <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-4">
        cc-deck
      </h1>

      <p class="text-xl md:text-2xl text-accent font-medium mb-6">
        Your Claude Code command center.
      </p>

      <p class="text-lg text-muted max-w-xl mx-auto mb-10">
        The TweetDeck for Claude Code. A Zellij sidebar plugin to manage all your AI coding sessions from one place.
      </p>

      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/docs/"
          class="inline-flex items-center gap-2 bg-accent text-white font-semibold px-6 py-3 rounded-lg hover:bg-accent/90 transition-colors"
        >
          Read the Docs
        </a>
        <a
          href="https://github.com/cc-deck/cc-deck"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 border border-slate-600 text-slate-300 font-semibold px-6 py-3 rounded-lg hover:border-slate-400 hover:text-white transition-colors"
        >
          GitHub
        </a>
      </div>
    </div>
  </section>
</Layout>
